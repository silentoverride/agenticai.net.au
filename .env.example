# Retell (voice agent)
PUBLIC_RETELL_PUBLIC_KEY=key_xxxxxxxxxxxxxxxxxxxxx
PUBLIC_RETELL_VOICE_AGENT_ID=agent_xxxxxxxxxxxxxxxxxxx
PUBLIC_RETELL_VOICE_AGENT_VERSION=0
PUBLIC_RETELL_CALLBACK_PHONE_NUMBER=+61000000000
PUBLIC_RETELL_CALLBACK_COUNTRIES=AU
PUBLIC_RETELL_RECAPTCHA_KEY=
RETELL_API_KEY=key_xxxxxxxxxxxxxxxxxxxxx
RETELL_VOICE_AGENT_ID=agent_xxxxxxxxxxxxxxxxxxx
RETELL_VOICE_AGENT_VERSION=0

# Stripe
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxx
PUBLIC_SITE_URL=http://localhost:5173
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxx

# Twilio (SMS)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_FROM_NUMBER=+61400000000
TWILIO_MESSAGING_SERVICE_SID=MGxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Retell webhook secret
RETELL_TWILIO_WEBHOOK_SECRET=replace_with_shared_secret
ASSESSMENT_REPORT_AGENT_WEBHOOK_URL=https://report-agent.example.com/webhook
ASSESSMENT_REPORT_AGENT_WEBHOOK_SECRET=replace_with_report_agent_secret
ASSESSMENT_REPORT_PROCESS_CALL_ENDED=false

# SendGrid email delivery (required for report pipeline)
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DEFAULT_FROM_EMAIL=hello@agenticai.net.au
DEFAULT_FROM_NAME=Agentic AI

# Report pipeline
REPORTS_DIR=./app_data/reports
PRESENTON_API_KEY=ptn_xxxxxxxxxxxxxxxxxxxxx
PRESENTON_API_URL=https://api.presenton.ai/v1

# LLM (OpenAI-compatible API — Ollama, OpenRouter, etc.)
OLLAMA_BASE_URL=https://api.ollama.ai
OLLAMA_API_KEY=your-api-key
OLLAMA_MODEL=kimi-k2.6:cloud

# Cloudflare
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token

# Cloudflare Web Analytics (optional — add beacon token from your Cloudflare dashboard)
# Enable at: https://dash.cloudflare.com → your domain → Analytics & Logs → Web Analytics
PUBLIC_CLOUDFLARE_ANALYTICS_TOKEN=your_cloudflare_analytics_token

# Internal pipeline runner (queue consumer → Pages Functions)
# Generate with: openssl rand -base64 32
INTERNAL_SECRET=replace_with_random_32_byte_base64
SELF_URL=https://agenticai.net.au
